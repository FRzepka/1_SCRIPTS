@misc{LFP_DoE_Cycle_Aging_Dataset,
  title = {Design of {{Experiments}} for {{Cyclic Aging}} of {{LFP}} 18650 {{Cells}}: {{Impact}} of {{Charge}}/{{Discharge C-Rates}}, {{Depth}} of {{Discharge}}, and {{Temperature}} on {{Battery Degradation}}},
  shorttitle = {Design of {{Experiments}} for {{Cyclic Aging}} of {{LFP}} 18650 {{Cells}}},
  author = {Rzepka, Florian},
  year = 2025,
  month = nov,
  publisher = {Technische Universit\"at Berlin},
  doi = {10.14279/DEPOSITONCE-24800},
  urldate = {2025-12-02},
  abstract = {This dataset comprises experimental data from a comprehensive Design of Experiments (DoE) study investigating the cyclic aging behavior of Lithium Iron Phosphate (LFP) 18650 battery cells under varying operational conditions. The study employs both full factorial and fractional factorial experimental designs to systematically assess the influence of three primary factors on battery degradation: Charge C-Rate: 0.5C to 0.9C (0.9-1.62 A) Discharge C-Rate: 1C to 2.5C (1.8-4.5 A) Depth of Discharge (DOD): 45\% to 65\% (0.81-1.17 Ah) All cycling experiments were conducted at a controlled ambient temperature of 25{$^\circ$}C. The experimental plan includes 15 test cells assigned to eight different factorial combinations, with each condition tested in duplicate to ensure reproducibility. Each cell underwent multiple aging loops. The dataset contains high-resolution time-series measurements recorded at 1 Hz sampling frequency, including voltage, current, temperature, and auxiliary parameters across multiple test steps. Data are stored in partitioned Parquet format for efficient access and analysis, enabling investigation of capacity fade, impedance growth, and state-of-health degradation mechanisms under controlled cycling protocols.},
  collaborator = {{Technische Universit\"at Berlin} and Mano, Schmitz},
  copyright = {Creative Commons Attribution 4.0 International},
  langid = {english},
  keywords = {18650,battery aging,cyclic aging,Design of Experiments (DoE),Lithium Iron Phosphate (LFP)}
}

